APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO
LOG_DIR_ROOT=/var/log/wormhole
LOG_RETENTION_DAYS=7

MARIADB_DATABASE=radius
MARIADB_USER=radius
MARIADB_PASSWORD=change-me-db-password
MARIADB_ROOT_PASSWORD=change-me-root-password
MYSQL_GENERAL_LOG=OFF
MYSQL_SLOW_LOG_THRESHOLD_MS=1000

RADIUS_DB_PORT=3306
RADIUS_DB_NAME=radius
RADIUS_DB_USER=radius
RADIUS_DB_PASSWORD=change-me-db-password
RADIUS_SHARED_SECRET=change-me-radius-secret

ADMIN_PORTAL_PORT=8080
ADMIN_BIND_PORT=8000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_SESSION_SECRET=change-me-session-secret-minimum-32-chars

CA_API_TOKEN=change-me-internal-api-token
INTERNAL_API_BIND_PORT=9000
CA_COMMON_NAME=Wormhole VPN Internal CA
CA_ORGANIZATION=Wormhole VPN
CA_VALIDITY_DAYS=3650
SERVER_CERT_VALIDITY_DAYS=825
CLIENT_CERT_VALIDITY_DAYS=365
P12_EXPORT_PASSWORD=

VPN_SERVER_HOST=vpn.example.com
VPN_SERVER_ALT_NAMES=
VPN_TCP_PORT=443
VPN_UDP_PORT=443
VPN_NETWORK=10.88.0.0
VPN_NETMASK=255.255.255.0
VPN_MAX_CLIENTS=16
VPN_DNS_1=1.1.1.1
VPN_DNS_2=8.8.8.8
VPN_IDLE_TIMEOUT=1200
VPN_MOBILE_IDLE_TIMEOUT=1800
VPN_SESSION_TIMEOUT=28800
VPN_STATS_REPORT_TIME=300
VPN_DEFAULT_DOMAIN=
OCSERV_NAT_DEVICE=eth0
